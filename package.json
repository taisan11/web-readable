{
  "name": "@web-readable/core",
  "version": "0.1.0",
  "description": "Fast article extraction and HTML-to-Markdown conversion powered by Rust.",
  "license": "MIT",
  "repository": "https://github.com/taisan11/web-readable",
  "publishConfig": { "access": "public" },
  "main": "index.js",
  "types": "index.d.ts",
  "packageManager": "bun@1.3.14",
  "files": ["index.js", "index.d.ts", "*.node"],
  "engines": {
    "node": ">= 16"
  },
  "scripts": {
    "build": "napi build --release",
    "test": "cargo test",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2"
  },
  "napi": {
    "binaryName": "web-readable",
    "targets": ["x86_64-unknown-linux-gnu", "x86_64-unknown-linux-musl", "aarch64-unknown-linux-gnu", "aarch64-apple-darwin", "x86_64-apple-darwin", "x86_64-pc-windows-msvc", "aarch64-pc-windows-msvc"]
  }
}
